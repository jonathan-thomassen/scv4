{
    "C_Cpp.intelliSenseEngine": "disabled",
    "clangd.path": "/usr/bin/clangd-21",
    "clangd.arguments": [
        "--clang-tidy",
        "--compile-commands-dir=${workspaceFolder}/build"
    ],
    "cmake.configureArgs": [
        "-DTILENGINE_DIR=${env:HOME}/dev/Tilengine"
    ],
    "files.exclude": {
        "build/**": true,
        ".cache/**": true
    },
    "search.exclude": {
        "build/**": true,
        ".cache/**": true
    }
}